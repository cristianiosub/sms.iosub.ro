Options -Indexes -MultiViews -ExecCGI
ServerSignature Off

# ============================================================
# Force HTTPS
# ============================================================
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} ^sms\.iosub\.ro$ [NC]
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ============================================================
# Blocheaza path traversal in URL
# ============================================================
RewriteCond %{REQUEST_URI} \.\. [NC]
RewriteRule .* - [F,L]

# ============================================================
# Blocheaza scanere comune
# ============================================================
RewriteCond %{HTTP_USER_AGENT} (sqlmap|nikto|nessus|masscan|zgrab|dirbuster|gobuster|wfuzz|nuclei|hydra|medusa|burpsuite) [NC]
RewriteRule .* - [F,L]

# ============================================================
# Remove .php extension & route everything through index.php
# ============================================================
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]

# ============================================================
# Security Headers
# ============================================================
<IfModule mod_headers.c>
    Header always set X-Frame-Options "DENY"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; form-action 'self'; frame-ancestors 'none'; base-uri 'self'"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=()"
    Header always set Cross-Origin-Opener-Policy "same-origin"
    Header always set Cross-Origin-Resource-Policy "same-origin"
    Header always unset X-Powered-By
    Header always unset Server
    # Nu cache-ui raspunsuri PHP (date sensibile)
    <FilesMatch "\.php$">
        Header always set Cache-Control "no-store, no-cache, must-revalidate, private"
        Header always set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# ============================================================
# Block access to sensitive files & directories
# ============================================================
# Fisiere sensibile
<FilesMatch "(^\.htaccess|config\.php|\.sql|\.log|\.env|composer\.json|composer\.lock|\.bak|\.backup|\.old|\.orig|\.phar|check_msg\.php)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Directoare sensibile — sursa, config, cron, instalare, log-uri, temp
<DirectoryMatch "^.*(config|src|cron|install|logs|tmp)">
    Order allow,deny
    Deny from all
</DirectoryMatch>

# Blocheaza executia PHP in directorul tmp (protectie dubla)
<FilesMatch "\.ph(p[0-9]?|tml|ar)$">
    <If "%{REQUEST_URI} =~ m#/tmp/#">
        Order Allow,Deny
        Deny from all
    </If>
</FilesMatch>

# Blocheaza metode HTTP periculoase
<LimitExcept GET POST HEAD>
    Order Allow,Deny
    Deny from all
</LimitExcept>

# ============================================================
# Static assets caching
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css               "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png              "access plus 1 month"
    ExpiresByType image/svg+xml          "access plus 1 month"
    ExpiresByType font/woff2             "access plus 1 year"
</IfModule>

# ============================================================
# Disable ETags
# ============================================================
FileETag None
<IfModule mod_headers.c>
    Header unset ETag
</IfModule>

# ============================================================
# PHP settings
# ============================================================
<IfModule mod_php8.c>
    php_flag display_errors Off
    php_value upload_max_filesize 20M
    php_value post_max_size 22M
    php_value max_execution_time 120
    php_value memory_limit 256M
    php_flag session.cookie_httponly On
    php_flag session.cookie_secure On
    php_value session.cookie_samesite Lax
    php_flag session.use_strict_mode On
</IfModule>
